# Credentials used during Astro build to fetch protected WP JSON content.
# Use the directory/basic-auth credentials that protect /wpheadless/wp-json/*.
WP_DIRECTORY_USER=
WP_DIRECTORY_PASS=

# Optional fallback variable names (supported by src/lib/wp.js).
WP_BASIC_USER=
WP_BASIC_PASS=
WP_USER=
WP_PASS=
