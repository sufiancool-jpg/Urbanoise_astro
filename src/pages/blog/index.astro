---
import GoogleTag from "../../components/GoogleTag.astro";
import { fetchAllWpPosts } from "../../lib/wp-posts.js";

const siteUrl = "https://urbanoise.com";

const stripHtml = (value) =>
  value
    ? value
        .replace(/<[^>]+>/g, " ")
        .replace(/&nbsp;/gi, " ")
        .replace(/&amp;/gi, "&")
        .replace(/&#038;/g, "&")
        .replace(/&#8217;/g, "'")
        .replace(/&#8220;/g, '"')
        .replace(/&#8221;/g, '"')
        .replace(/&#8211;/g, "-")
        .replace(/\s+/g, " ")
        .trim()
    : "";

const clampText = (value, max = 170) =>
  value && value.length > max ? `${value.slice(0, max).trimEnd()}...` : value;

const formatDate = (dateValue) => {
  if (!dateValue) return "";
  const parsed = new Date(dateValue);
  if (Number.isNaN(parsed.getTime())) return "";
  return parsed.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
};

const posts = await fetchAllWpPosts();
const blogPosts = posts.map((post, index) => {
  const key = post?.slug || `post-${post?.id ?? index}`;
  const title = stripHtml(post?.title?.rendered ?? "Untitled");
  const path = post?.slug ? `/blog/${post.slug}/` : "/blog/";
  const date = post?.date ?? "";
  const modified = post?.modified ?? post?.date ?? "";
  const dateLabel = formatDate(date);

  const featured = post?._embedded?.["wp:featuredmedia"]?.[0];
  const featuredAlt = featured?.alt_text || title;
  const featuredUrl = post?.__localFeaturedUrl || featured?.source_url || "";

  const contentHtml = post?.content?.rendered || post?.excerpt?.rendered || "";
  const excerptText = clampText(
    stripHtml(post?.excerpt?.rendered ?? post?.content?.rendered ?? ""),
    175
  );

  return {
    key,
    title,
    path,
    date,
    modified,
    dateLabel,
    featuredAlt,
    featuredUrl,
    excerptText,
    contentHtml,
    slug: post?.slug ?? "",
  };
});

const pageTitle = "Blog | Urbanoise";
const pageDescription = clampText(
  blogPosts.length
    ? blogPosts
        .slice(0, 3)
        .map((post) => post.excerptText)
        .filter(Boolean)
        .join(" ")
    : "Urbanoise journal: architectural documentary essays, film insights, and spatial storytelling notes.",
  160
);
const canonicalUrl = new URL("/blog/", siteUrl).href;
const ogImage = `${siteUrl}/Opengraph.jpg`;
const featuredPost = blogPosts[0] ?? null;
const thumbnailPosts = blogPosts.slice(1);
const featuredPreview = (() => {
  if (!featuredPost) return "";
  const text = stripHtml(featuredPost.contentHtml || featuredPost.excerptText || "");
  if (!text) return "";
  const previewLength = Math.max(140, Math.min(420, Math.round(text.length * 0.2)));
  return clampText(text, previewLength);
})();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Urbanoise Blog",
  url: canonicalUrl,
  description: pageDescription,
  blogPost: blogPosts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    datePublished: post.date || undefined,
    dateModified: post.modified || undefined,
    url: post.slug ? new URL(`/blog/${post.slug}/`, siteUrl).href : canonicalUrl,
  })),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Urbanoise" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <script is:inline>
      (() => {
        try {
          if (window.sessionStorage.getItem("urbanoise:page-transition-entry") === "1") {
            document.documentElement.classList.add("page-transition-entry");
          }
        } catch (_error) {}
      })();
    </script>
    <GoogleTag />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="stylesheet" href="/styles-post.css" />
  </head>
  <body class="post-body blog-index-body">
    <div class="page-transition-overlay" aria-hidden="true"></div>

    <header class="site-header post-header" aria-label="Primary">
      <div class="site-brand">
        <a class="site-brand-link" href="/#video">Urbanoise</a>
      </div>
      <button
        class="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="primary-navigation"
        aria-hidden="true"
        tabindex="-1"
        hidden
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span class="sr-only">Toggle menu</span>
      </button>
      <nav class="nav-links" id="primary-navigation">
        <a class="nav-link" href="/#video">Home</a>
        <a class="nav-link" href="/start-a-project">Start a project</a>
        <a class="nav-link" href="/about-us">About us</a>
        <a class="nav-link" href="mailto:info@urbanoise.com">Contact</a>
      </nav>
    </header>

    <main class="post-page blog-page-main">
      <section class="blog-board" aria-label="Blog topics">
        {featuredPost ? (
          <article class="blog-featured" id={featuredPost.slug || featuredPost.key}>
            <a class="blog-featured-link" href={featuredPost.path}>
              {featuredPost.featuredUrl ? (
                <figure class="blog-featured-media">
                  <img
                    src={featuredPost.featuredUrl}
                    alt={featuredPost.featuredAlt}
                    loading="eager"
                    decoding="async"
                  />
                </figure>
              ) : null}
              <div class="blog-featured-copy">
                {featuredPost.dateLabel ? (
                  <p class="blog-featured-date">
                    <time datetime={featuredPost.date}>{featuredPost.dateLabel}</time>
                  </p>
                ) : null}
                <h1 class="blog-featured-title">{featuredPost.title}</h1>
                {featuredPreview ? <p class="blog-featured-excerpt">{featuredPreview}</p> : null}
                <span class="blog-featured-more">More</span>
              </div>
            </a>
          </article>
        ) : null}

        {thumbnailPosts.length ? (
          <div class="blog-masonry" data-blog-grid>
            {thumbnailPosts.map((post) => (
              <article class="blog-card" id={post.slug || post.key}>
                <a class="blog-card-link" href={post.path}>
                  <figure class="blog-card-media">
                    {post.featuredUrl ? (
                      <img src={post.featuredUrl} alt={post.featuredAlt} loading="lazy" decoding="async" />
                    ) : (
                      <div class="blog-card-placeholder">Urbanoise</div>
                    )}
                  </figure>
                  <div class="blog-card-content">
                    {post.dateLabel ? (
                      <p class="blog-card-date">
                        <time datetime={post.date}>{post.dateLabel}</time>
                      </p>
                    ) : null}
                    <h2 class="blog-card-title">{post.title}</h2>
                    {post.excerptText ? <p class="blog-card-excerpt">{post.excerptText}</p> : null}
                    <span class="blog-card-more">More</span>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : null}

        {!blogPosts.length ? <p class="blog-empty">No posts are available yet.</p> : null}
        <p class="blog-seo-cta">
          Planning an architectural documentary film for your studio or project?{" "}
          <a href="/start-a-project">Start a project</a>.
        </p>
      </section>
    </main>

    <section class="footer-page" id="contact" aria-label="Get in touch">
      <div class="footer-inner">
        <div class="footer-newsletter">
          <p class="footer-lead">
            Sign up to receive updates on new work, behind-the-scenes notes, and screenings.
          </p>
          <form
            class="footer-newsletter-form"
            method="POST"
            action="https://d662e9e1.sibforms.com/serve/MUIFALaUJNiZduD2dWCUsUfuBClVksUauK1s3hNzI5niw4gMi_T2x4Xg5mNT5j0y1zKu6YIg94oAIPzy9pL3-uQMD3Vk0cz5TT_11GOsyoWvXN5eb1oli-pCM9eQXfRm93uhBy82UJ9q2RCF_FqGIIdeZpXUo_sCFavLq_oz7tJanmjQ_jxupGAIvdJCra8XmafQJXsr6MGnfHgyAw=="
            target="brevo-target"
          >
            <label class="sr-only" for="newsletter-email">Email address</label>
            <div class="footer-newsletter-field">
              <input
                id="newsletter-email"
                name="EMAIL"
                type="email"
                placeholder="Email address"
                required
                autocomplete="email"
              />
              <button type="submit">Subscribe</button>
            </div>
            <input
              type="text"
              name="email_address_check"
              value=""
              class="input--hidden"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;"
            />
            <input type="hidden" name="locale" value="en" />
            <input type="hidden" name="html_type" value="simple" />
          </form>
          <iframe
            name="brevo-target"
            class="brevo-iframe"
            title="Brevo submission target"
            aria-hidden="true"
            style="position:absolute;width:1px;height:1px;opacity:0;pointer-events:none;border:0;clip-path:inset(50%);overflow:hidden;"
          ></iframe>
          <p class="footer-newsletter-status" role="status" aria-live="polite"></p>
        </div>
        <div class="footer-meta">
          <div class="footer-social" aria-label="Urbanoise social links">
            <a
              class="footer-social-link"
              href="https://www.linkedin.com/company/urba-noise/"
              target="_blank"
              rel="noreferrer noopener"
              aria-label="LinkedIn"
            >
              <svg viewBox="0 0 24 24" role="img">
                <path d="M4.5 9h3v12h-3zM6 4.5a1.75 1.75 0 1 1-1.75 1.75A1.75 1.75 0 0 1 6 4.5zM9 9h2.8v1.7h.1a3.08 3.08 0 0 1 2.8-1.6c3 0 3.5 2 3.5 4.6V21h-3v-5.1c0-1.3 0-3-1.8-3s-2 1.4-2 2.9V21H9z" />
              </svg>
            </a>
          </div>
          <a class="footer-back" href="/#video">Back to main page</a>
          <p class="footer-note">Urbanoise © 2025 <a class="footer-note-link" href="/imprint">Imprint</a> <a class="footer-note-link" href="/blog/">Blog</a></p>
        </div>
      </div>
    </section>

    <script type="module" src="/nav-menu.js"></script>
    <script type="module" src="/page-transition.js"></script>
    <style is:global>
      body.blog-index-body {
        background: #000;
        color: #fff;
      }

      .blog-index-body .footer-page {
        background: #000;
      }

      .blog-index-body .post-header {
        position: fixed;
        top: 1.75rem;
        left: 2.25rem;
        right: 2.25rem;
        padding: 0;
        background: transparent;
        border: 0;
        backdrop-filter: none;
        z-index: 20;
      }

      .blog-index-body .site-brand-link,
      .blog-index-body .nav-link {
        color: #fff;
      }

      .blog-index-body .nav-link:hover,
      .blog-index-body .nav-link:focus-visible {
        background: transparent;
      }

      .blog-index-body .post-page.blog-page-main {
        min-height: auto;
        padding: 7.8rem clamp(1rem, 2.5vw, 2.1rem) 3rem;
        justify-content: center;
      }

      .blog-index-body .blog-board {
        width: min(1220px, 100%);
      }

      .blog-index-body .blog-featured {
        width: min(500px, 100%);
        margin: 0 auto 1.4rem;
      }

      .blog-index-body .blog-featured-link {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: clamp(150px, 22vw, 240px);
        overflow: hidden;
        border-radius: 22px;
        background: #000;
        color: #fff;
        text-decoration: none;
        box-shadow: none;
        border: 1px solid rgba(255, 255, 255, 0.22);
      }

      .blog-index-body .blog-featured-media {
        position: absolute;
        inset: 0;
        margin: 0;
      }

      .blog-index-body .blog-featured-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: brightness(0.42) saturate(1.1);
        transform: scale(1.04);
      }

      .blog-index-body .blog-featured-copy {
        position: relative;
        z-index: 1;
        width: min(88%, 520px);
        margin: 0 auto;
        padding: clamp(0.85rem, 2.2vw, 1.45rem) clamp(0.65rem, 1.6vw, 1rem);
        text-align: center;
      }

      .blog-index-body .blog-featured-date {
        margin: 0 0 0.44rem;
        font-family: var(--font-head);
        font-size: 0.58rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.78);
      }

      .blog-index-body .blog-featured-title {
        margin: 0;
        font-family: var(--font-logo);
        font-weight: 800;
        font-size: clamp(1.25rem, 1.2vw + 0.72rem, 2rem);
        line-height: 1.06;
        letter-spacing: 0.01em;
        text-transform: uppercase;
        color: #fff;
      }

      .blog-index-body .blog-featured-excerpt {
        margin: 0.65rem auto 0;
        width: min(50ch, 100%);
        font-size: clamp(0.8rem, 0.34vw + 0.72rem, 0.95rem);
        line-height: 1.36;
        color: rgba(255, 255, 255, 0.9);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .blog-index-body .blog-featured-more {
        display: inline-flex;
        margin-top: 0.8rem;
        padding: 0.36rem 0.62rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.62);
        font-family: var(--font-head);
        font-size: 0.54rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #fff;
      }

      .blog-index-body .blog-masonry {
        column-count: 3;
        column-gap: 1.15rem;
      }

      .blog-index-body .blog-card {
        break-inside: avoid;
        margin-bottom: 1.15rem;
      }

      .blog-index-body .blog-card-link {
        display: block;
        overflow: hidden;
        border-radius: 16px;
        background: #000;
        color: #fff;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.22);
        box-shadow: none;
        transition: transform 0.24s ease, border-color 0.24s ease;
      }

      .blog-index-body .blog-card-link:hover,
      .blog-index-body .blog-card-link:focus-visible {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.4);
      }

      .blog-index-body .blog-card-media {
        margin: 0;
        background: #111;
        overflow: hidden;
      }

      .blog-index-body .blog-card-media img {
        width: 100%;
        height: auto;
        display: block;
      }

      .blog-index-body .blog-card-placeholder {
        width: 100%;
        min-height: 210px;
        display: grid;
        place-items: center;
        background: #111;
        font-family: var(--font-head);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-size: 0.74rem;
        color: rgba(255, 255, 255, 0.55);
      }

      .blog-index-body .blog-card-content {
        padding: 1rem 1rem 1.06rem;
      }

      .blog-index-body .blog-card-date {
        margin: 0 0 0.46rem;
        font-family: var(--font-head);
        font-size: 0.64rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.62);
      }

      .blog-index-body .blog-card-title {
        margin: 0;
        font-family: var(--font-logo);
        font-weight: 800;
        font-size: clamp(1.05rem, 0.45vw + 0.96rem, 1.28rem);
        line-height: 1.22;
        letter-spacing: 0.02em;
        color: #fff;
      }

      .blog-index-body .blog-card-excerpt {
        margin: 0.62rem 0 0;
        font-size: 0.91rem;
        line-height: 1.48;
        color: rgba(255, 255, 255, 0.78);
      }

      .blog-index-body .blog-card-more {
        display: inline-flex;
        margin-top: 0.85rem;
        padding: 0.48rem 0.8rem;
        border-radius: 999px;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.52);
        color: #fff;
        font-family: var(--font-head);
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .blog-index-body .blog-empty {
        margin: 0;
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.82);
      }

      .blog-index-body .blog-seo-cta {
        margin: 1.2rem 0 0;
        font-size: clamp(0.88rem, 0.34vw + 0.8rem, 1rem);
        line-height: 1.45;
        color: rgba(255, 255, 255, 0.82);
      }

      .blog-index-body .blog-seo-cta a {
        color: #fff;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }

      @media (max-width: 980px) {
        .blog-index-body .blog-masonry {
          column-count: 2;
        }

        .blog-index-body .blog-featured-copy {
          width: min(88%, 520px);
        }
      }

      @media (max-width: 768px) {
        .blog-index-body .post-header {
          top: 1.25rem;
          left: 1.4rem;
          right: 1.4rem;
        }

        .blog-index-body .post-page.blog-page-main {
          padding: 6.8rem 1rem 2rem;
        }

        .blog-index-body .blog-featured {
          margin-bottom: 1.3rem;
        }
      }

      @media (max-width: 640px) {
        .blog-index-body .post-header {
          top: 1rem;
          left: 1rem;
          right: 1rem;
        }

        .blog-index-body .blog-masonry {
          column-count: 1;
          column-gap: 0;
        }

        .blog-index-body .blog-card {
          margin-bottom: 0.95rem;
        }

        .blog-index-body .blog-featured-link {
          min-height: 140px;
        }

        .blog-index-body .blog-featured-copy {
          width: 92%;
          padding: 0.9rem 0.58rem 1rem;
        }
      }
    </style>
  </body>
</html>
